                            <th class="text-muted ">Description</th>
                            <th class="text-muted ">Date Submitted</th>
                            <th class="text-muted ">Status</th>


                        </tr>
                    </thead>
                    <tbody id="tblBody" class="table table-body">
                        
                        @*                                           @{
                                                await Html.RenderPartialAsync("~/Views/Ticket/_TicketList.cshtml");
                                            } *@

                    </tbody>
                </table>

            </div>


        </div>
