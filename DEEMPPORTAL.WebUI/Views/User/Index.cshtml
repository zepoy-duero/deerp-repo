@{
	Layout = "_Layout";
	ViewData["Title"] = "Users";
}

<!-- Modal here -->
<div class="modal fade" id="modalSaveUserAccount" tabindex="-1" aria-labelledby="modalSaveUserAccountLabel">
	<div class="modal-dialog modal-lg">
		<div class="modal-content">
			<form id="frmUserAccountDetails" autocomplete="off">
				@Html.AntiForgeryToken()
				<div class="modal-header">
					<h1 class="modal-title fs-5" id="modalSaveUserAccountLabel">Create / Update User Account</h1>
					<button type="button" class="btn-close" onclick="cancelModal(this)"></button>
				</div>
				<div class="modal-body">
					<input id="inpUserCode" type="hidden" name="USER_CODE" value="" />
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Organization: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<select id="selOrgCode" class="form-select form-control rounded-1 required" name="ORG_CODE"></select>
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Location: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<select id="selLocCode" class="form-select form-control rounded-1 required" name="LOC_CODE"></select>
						</div>
					</div>
					<div class="form-group row">
						<div class="col-sm-3"></div>
						<div class="col-sm-8">
							<hr style="border: none; border-bottom: 1px dashed #ccc" />
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Employee Name: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<div id="empSearchInputContainer">
								<select id="selEmpCode" class=""></select>
							</div>
							<div id="empLabelInputContainer" class="d-none">
								<input id="inpEmpName" class="form-control rounded-1" type="text" value="" />
							</div>
						</div>
						<input type="hidden" class="form-control required" id="inpEmpCode" name="EMP_CODE" value="" />
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Emp. Id: </label>
						<div class="col-sm-2">
							<input type="text" class="form-control rounded-1" id="inpEmpId" name="" value="" readonly />
						</div>
						<label class="col-sm-2 text-end">Emp. Status:</label>
						<div class="col-sm-4">
							<input type="text" class="form-control rounded-1" id="inpEmpStatus" name="" value="" readonly />
						</div>
					</div>
					<div class="form-group row">
						<div class="col-sm-3"></div>
						<div class="col-sm-8">
							<hr style="border: none; border-bottom: 1px dashed #ccc" />
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Department: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<select id="selDeptCode" class="form-select form-control rounded-1" name="DEPT_CODE"></select>
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Role: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<select id="selRoleCode" class="form-select form-control rounded-1" name="ROLE_CODE"></select>
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Email Address: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<input type="text" id="inpEmailAddress" class="form-control rounded-1 required" placeholder="example@dahbashi.com" name="EMAIL_ADDRESS">
						</div>
					</div>
					<div class="row py-2">
						<div class="col-3"></div>
						<div class="col-8 px-4">
							<div class="alert-danger px-3">
								<small class="text-danger small"><strong>Important Note:</strong> This email will serve as your primary correspondence address for the entire application. It will be used across all modules requiring email services. Ensure the address is active and up to date.</small>
							</div>
						</div>
					</div>
					<div class="form-group row py-0">
						<div class="col-sm-3"></div>
						<div class="col-sm-8">
							<hr style="border: none; border-bottom: 1px dashed #ccc" />
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Username: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<input type="text" id="inpUserName" class="form-control rounded-1 required" name="USERNAME" placeholder="Please enter the username">
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Password: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<input type="password" id="inpPassword" class="form-control rounded-1 required" name="PASSWORD" placeholder="Please enter the password.">
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">&nbsp;</label>
						<div class="col-sm-8">
							<div class="form-check p-0">
								<input class="form-check-input" type="checkbox" value="" id="checkChecked" onchange="showPassword(this)">
								<label class="form-check-label" for="checkChecked">
									Show Password
								</label>
							</div>
						</div>
					</div>
					<div class="form-group row py-0">
						<div class="col-sm-3"></div>
						<div class="col-sm-8">
							<hr style="border: none; border-bottom: 1px dashed #ccc" />
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Enable 2FA: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<select id="selIs2FAEnabled" class="form-select rounded-1" name="IS_2FA_ENABLED">
								<option value="Y">Enabled</option>
								<option value="N">Disabled</option>
							</select>
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end"></label>
						<div class="col-8 px-4">
							<div class="alert-primary px-3 mb-3">
								<small class="text-info small"><strong>Important Note:</strong> When signing in, you will enter your password and a confirmation code. We will send it to you via email.</small>
							</div>
						</div>
					</div>
					<div class="form-group row py-0">
						<div class="col-sm-3"></div>
						<div class="col-sm-8">
							<hr style="border: none; border-bottom: 1px dashed #ccc" />
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Status: <span class="text-danger">*</span></label>
						<div class="col-sm-3">
							<select id="selIsActive" class="form-select form-control rounded-1 required" name="IS_ACTIVE">
								<option value="Y">Active</option>
								<option value="N">Inactive</option>
							</select>
						</div>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" onclick="cancelModal(this)">Close</button>
					<button type="button" class="btn btn-danger bg-accent" onclick="submitSaveUser(this)">Save changes</button>
				</div>
			</form>
		</div>
	</div>
</div>


<!-- Main content here -->
<div class="container">
	<div class="page-inner">
		<div class="d-flex justify-content-between align-items-center">
			<h5 class="page-title mb-3 fs-5 fw-bolder text-main">
				User Accounts
			</h5>
			<div class="d-flex gap-2">
				<small><span class=""></span><span id="totalEmployees" class="badge badge-primary rounded-1"></span> Total Employees</small>
				<small><span class=""></span><span id="totalOnPayroll" class="badge badge-primary rounded-1"></span> Total On Payroll</small>
				<small><span class=""></span><span id="totalConsultants" class="badge badge-primary rounded-1"></span> Total Consultants</small>
				<small><span class=""></span> | </small>
				<small><span class=""></span><span id="totalCount" class="badge badge-secondary rounded-1"></span> Total Users</small>
				<small><span class=""></span><span id="totalActive" class="badge badge-success rounded-1"></span> Active Users</small>
				<small><span class=""></span><span id="totalInactive" class="badge badge-danger rounded-1"></span> Inactive Users</small>
			</div>
		</div>
		<div class="page-category">
			<div class="card">
				<div class="card-header p-3">
					<div class="row justify-content-between">
						<div class="col-2">
							<button class="btn btn-danger btn-sm" onclick="showModalCreateUserAccount(this)">
								<i class="fas fa-plus xsmall"></i>
								New
							</button>
						</div>
						<div class="col-5">

							@* <label for="select-organization" class="form-label fw-semibold">Choose Organization</label> *@
							<select id="select-organization" class="form-select select-organization">
								<option>Choose Organization</option>
							</select>

						</div>
						<div class="col-5">
							<div class="input-group">
								<input id="inpSearch" type="text" class="form-control rounded-start-1"
											 placeholder="Search for username or email address" aria-label="User Account Search">
								<button id="btnSearch" class="btn btn-danger bg-accent px-2 rounded-start-0" type="button" onclick="submitSearchUserAccount(this)">
									<i class="fas fa-search"></i>
								</button>
							</div>
						</div>
					</div>
				</div>
				<div class="card-body p-1">
					<div class="row">
						<div class="">
							<table id="tblUsers" class="table table-sm mb-0">
								<thead class="table-light fw-bold">
									<tr>
										<td class="text-muted" style="width: 1%;">#</td>
										<td style="width: 10%"></td>
										<td style="width: 50%" class="text-muted">Employee&nbsp;Name</td>
										<td style="width: 10%" class="text-muted">Actions</td>
									</tr>
								</thead>
								<tbody></tbody>
								<tfoot>
									<tr>
										<td colspan="8">
											<div class="d-flex align-items-center justify-content-between gap-2">
												<div></div>
												<div id="pagination" class="d-flex gap-2 align-items-center fw-bold">
													<label>Page no. </label>
													<div style="width: 110px">
														<select id="pageNo" class="form-select form-control rounded-1"
																		onchange="changePageNo(this.value)"></select>
													</div>
													<label>of <span id="pageTotal"></span></label>
												</div>
											</div>
										</td>
									</tr>
								</tfoot>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<!-- End of main content -->
@section Scripts {
	<script src="~/js/manage/users.js" asp-append-version="true"></script>
}