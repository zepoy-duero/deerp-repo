@{
	Layout = "_Layout";
	ViewData["Title"] = "Menus";
}

<!-- Modal here -->
<div class="modal fade" id="modalMainMenu" tabindex="-1" aria-labelledby="modalMainMenuLabel">
	<div class="modal-dialog modal-lg">
		<div class="modal-content">
			<form id="frmMenuItems">
				@Html.AntiForgeryToken()
				<div class="modal-header">
					<h1 class="modal-title fs-5" id="modalMainMenuLabel"></h1>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<div>
						<div class="form-group row align-items-center py-1">
							<label class="col-sm-3 text-end">Menu Type: <span class="text-danger">*</span></label>
							<div class="col-sm-8">
								<select id="selMenuType" class="form-control form-select rounded-1" onchange="selOnChangeMenuType(this)">
									<option value="main-menu">Main Menu</option>
									<option value="sub-menu">Sub Menu</option>
									<option value="sub-level-menu">Sub Level Menu</option>
								</select>
							</div>
						</div>
					</div>
					<div id="frmMenuItemEntries"></div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Seq. No.: <span class="text-danger">*</span></label>
						<div class="col-sm-8">
							<input id="inpSeqNo" type="number" class="form-control rounded-1 required" placeholder="" name="SEQ_NO">
						</div>
					</div>
					<div class="form-group row align-items-center py-1">
						<label class="col-sm-3 text-end">Status: <span class="text-danger">*</span></label>
						<div class="col-sm-3">
							<select id="selIsActive" class="form-select form-control rounded-1 required" name="IS_ACTIVE">
								<option value="Y">Active</option>
								<option value="N">Inactive</option>
							</select>
						</div>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" onclick="cancelModal(this)">Close</button>
					<button type="button" class="btn btn-danger bg-accent" onclick="submitMenuItems(this)">Save changes</button>
				</div>
			</form>
		</div>
	</div>
</div>


<!-- Main content here -->
<div class="container">
	<div class="page-inner">
		<div class="flex-column">
			<h5 class="page-title mb-3 fs-5 fw-bolder text-main">
				Menus
			</h5>
		</div>
		<div class="page-category">
			<div class="card rounded-1 shadow-none mb-2">
				<div class="card-body p-3">
					<div class="row justify-content-between">
						<div class="col-sm-4">
							<button class="btn btn-danger" onclick="showModalCreateMenuItems(this)"><i class="fas fa-plus"></i> New</button>
							<button id="btnDeleteMultiple" class="btn btn-light text-danger shadow-none d-none" onclick="deleteMultipleMenuItems(this)"><i class="fas fa-trash"></i> &nbsp;Delete Selected</button>
						</div>
						<div class="col-sm-6">
							<div class="input-group">
								<input id="inpSearchParam" type="text" class="form-control rounded-start-1"
											 placeholder="Search for menu name" aria-label="">
								<button id="" class="btn btn-danger bg-accent px-4 rounded-start-0" type="button" onclick="submitSearchMenu(this)">
									<i class="fas fa-search"></i>
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="card rounded-1 shadow-none">
				<div class="card-body p-1">
					<div class="row">
						<div class="table-responsive">
							<table id="tblMenuItems" class="table table-sm mb-0">
								<thead class="table-light fw-bold">
									<tr>
										<td class="text-muted" style="width: 1%;">#</td>
										<td class="text-center" style="width: 1%;"><input id="cbSelectAllRecords" type="checkbox" class="form-check-input p-2" style="border-width: 1.5px !important" /></td>
										<td style="width: 70px;"></td>
										<td style="width: 70px;" class="text-muted">Icon</td>
										<td class="text-muted">Menu&nbsp;Name</td>
										<td class="text-muted">Status</td>
										<td class="text-muted">Parent&nbsp;Menu</td>
										<td class="text-muted">Actions</td>
									</tr>
								</thead>
								<tbody></tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<!-- End of main content -->
@section Scripts {
	<script src="~/js/manage/menus.js" asp-append-version="true"></script>
}